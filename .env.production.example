# Production Environment Variables for Vercel
# Copy these to Vercel Dashboard → Settings → Environment Variables

# MongoDB Atlas Connection String (Required)
# Get this from MongoDB Atlas after creating your cluster
# Format: mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/organic-ecommerce?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/organic-ecommerce?retryWrites=true&w=majority

# JWT Secret (Required) - Use generated secret below
JWT_SECRET=pEpxsFdjUWiX64PE+FfjaNtvQ9lJ4IGWQxHe2G8TZr4=

# Razorpay Keys (Required for payments)
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Next.js Config (Optional - Vercel sets automatically)
# NODE_ENV=production
# NEXT_PUBLIC_API_URL is not needed - Vercel handles this automatically

# Notes:
# 1. Don't use localhost URLs in production
# 2. Vercel provides automatic domain: your-project.vercel.app
# 3. All NEXT_PUBLIC_* variables are exposed to the browser
# 4. Never commit this file with real values to Git
